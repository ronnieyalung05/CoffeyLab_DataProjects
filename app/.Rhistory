library(tidyverse)
library(GGally)
# Load exam scores data
exam_data <- read.csv("exam_scores.csv")
# Load bimodal data
bimodal <- read.csv("bimodal_mystery.csv")
# Load PluckData
load("PluckData.RData")
# Note: PluckData.RData creates an object called 'dataset'
# Let's also give it a clearer name
pluck_data <- dataset
# How many rows and columns?
dim(exam_data)
# What are the variable names?
names(exam_data)
# Quick overview of types and first values
glimpse(exam_data)
# Summary statistics for each variable
summary(exam_data)
# How many students in each section?
exam_data |> count(section)
# Count students with high study hours
exam_data |>
count(study_hours > 10)
# Cross-tabulation
exam_data |>
count(section, study_hours > 10)
# Your turn: explore pluck_data with dim(), names(), glimpse(), and summary()
# How many rows and columns?
dim(pluck_data)
# What are the variable names?
names(pluck_data)
# Quick overview of types and first values
glimpse(pluck_data)
# Summary statistics for each variable
summary(pluck_data)
# Overall mean
exam_data |>
summarize(mean_score = mean(score))
# Mean by section
exam_data |>
group_by(section) |>
summarize(mean_score = mean(score, na.rm=TRUE))
# SD by section
exam_data |>
group_by(section) |>
summarize(variability = var(score),
standard_deviation = sd(score))
# One way: filter then count, or use sum() on a logical
exam_data |>
filter(score > 90) |>
nrow()
# Alternative using sum on a logical:
sum(exam_data$score > 90)
# Your turn: group_by section, then summarize with mean(score > 80)
exam_data |>
group_by(section) |>
summarize(prop_score_over_80 = mean(score > 80)) # trues are 1, falses are 0. This is a neat trick. So the mean is the actual proportion(1s,0s)
# Mean GPA by Sex (hint: watch out for NA values!)
pluck_data |>
filter(GPA <= 4) |>
group_by(Sex) |>
summarize(mean_GPA = mean(GPA, na.rm=TRUE))
# Personality scores by sex
pluck_data |>
group_by(Sex) |>
summarize(mean_extraversion = mean(Extraversion, na.rm=TRUE),
mean_neuroticism = mean(Neurotocism, na.rm=TRUE))
# Compare mean and median for exam scores
exam_data |>
summarize(
mean_score = mean(score),
median_score = median(score),
)
# Mean vs median by section
exam_data |>
group_by(section) |>
summarize(
mean_score = mean(score),
median_score = median(score),
difference = mean_score - median_score
)
# Five-number summary for exam scores
summary(exam_data$score)
# Or more explicitly:
exam_data |>
summarize(
min = min(score),
Q1 = quantile(score, 0.25),
median = median(score),
Q3 = quantile(score, 0.75),
max = max(score)
)
# Five-number summary for GPA
summary(pluck_data$GPA)
pluck_data |>
drop_na(GPA) |>
summarize(
min = min(GPA),
Q1 = quantile(GPA, 0.25),
median = median(GPA),
Q3 = quantile(GPA, 0.75),
max = max(GPA)
)
# Calculate IQR and outlier fences
exam_summary <- exam_data |>
summarize(
Q1 = quantile(score, 0.25),
Q3 = quantile(score, 0.75),
IQR = Q3 - Q1,
lower_fence = Q1 - 1.5 * IQR,
upper_fence = Q3 + 1.5 * IQR
)
exam_summary
# How many potential outliers?
exam_data |>
filter(score < exam_summary$lower_fence | score > exam_summary$upper_fence)
# How many 999 values are there?
pluck_data %>%
count(GPA == 999)
# Recode 999 as NA (hint: use mutate with if_else)
pluck_data <- pluck_data |>
mutate(GPA = if_else(GPA == 999, NA, GPA))
# Verify the fix
summary(pluck_data$GPA)
# Base R histogram
hist(exam_data$score,
main = "Distribution of Exam Scores",
xlab = "Score",
col = "lightblue",
breaks = 15)
# ggplot2 histogram
ggplot(exam_data, aes(x = score)) +
geom_histogram(bins = 15, fill = "lightblue", color = "black") +
labs(title = "Distribution of Exam Scores", x = "Score", y = "Count") +
theme_minimal()
# Histogram of GPA (try bins = 10, then bins = 20)
ggplot(pluck_data, aes(x = GPA)) +
geom_histogram(bins = 10, fill = "lightgreen", color = "black") +
labs(title = "Distribution of GPAs", x = "GPA", y = "Count") +
theme_minimal()
ggplot(pluck_data, aes(x = GPA)) +
geom_histogram(bins = 20, fill = "lightpink", color = "black") +
labs(title = "Distribution of GPAs", x = "GPA", y = "Count") +
theme_minimal()
# Base R boxplot
boxplot(exam_data$score,
main = "Exam Score Distribution",
ylab = "Score",
col = "lightgreen")
# ggplot2 boxplot
ggplot(exam_data, aes(y = score)) +
geom_boxplot(fill = "lightgreen") +
labs(title = "Exam Score Distribution") +
theme_minimal()
# Compare sections with boxplots
ggplot(exam_data, aes(x = section, y = score, fill = section)) +
geom_boxplot() +
labs(title = "Exam Scores by Section", x = "Section", y = "Score") +
theme_minimal()
# Boxplots of personality by sex
# Hint: First, you may need to filter out NA values for Sex
extraversion_by_sex <- pluck_data |>
filter(!is.na(Sex)) |>
ggplot(aes(x = Sex, y = Extraversion, fill = Sex)) +
geom_boxplot() +
labs(title = "Extraversion by Sex", x = "Sex", y = "Extraversion Score") +
theme_minimal()
neurotocism_by_sex <- pluck_data |>
filter(!is.na(Sex)) |>
ggplot(aes(x = Sex, y = Neurotocism, fill = Sex)) +
geom_boxplot() +
labs(title = "Neurotocism by Sex", x = "Sex", y = "Neurotocism Score") +
theme_minimal()
library(patchwork)
extraversion_by_sex + neurotocism_by_sex
# Basic density plot
ggplot(exam_data, aes(x = score)) +
geom_density(fill = "lightgray", alpha = 0.7) +
labs(title = "Density of Exam Scores", x = "Score") +
theme_minimal()
# Compare sections with overlapping density plots
ggplot(exam_data, aes(x = score, fill = section, color = section)) +
geom_density(alpha = 0.4) +
labs(title = "Score Distribution by Section", x = "Score") +
theme_minimal()
# Density of GPA by Sex
pluck_data |>
filter(!is.na(Sex)) |>
ggplot(aes(x = GPA, fill = Sex, color = Sex)) +
geom_density(alpha = 0.3) +
labs(title = "GPA Distribution by Sex", x = "GPA", y = "Density") +
theme_minimal()
# Look at the boxplot
ggplot(bimodal, aes(y = score)) +
geom_boxplot(fill = "steelblue") +
labs(title = "Mystery Distribution") +
theme_minimal()
# Now look at the histogram
ggplot(bimodal, aes(x = score)) +
geom_histogram(bins = 30, fill = "steelblue", color = "black") +
labs(title = "Mystery Distribution Revealed") +
theme_minimal()
# Violin plot
ggplot(exam_data, aes(x = section, y = score, fill = section)) +
geom_violin() +
geom_boxplot(width = 0.1, fill = "white") +
labs(title = "Exam Scores by Section", x = "Section", y = "Score") +
theme_minimal()
# Violin plot of GPA by Sex
# Histogram with boxplot overlay
ggplot(pluck_data, aes(x = GPA)) +
geom_histogram(bins = 15, fill = "lightgray", color = "black") +
geom_boxplot(aes(y = -3), width = 2, fill = "lightblue") +
labs(title = "GPA Distribution with Boxplot", x = "GPA", y = "Count") +
theme_minimal()
# Raincloud plot for exam scores by section
ggplot(exam_data, aes(x = section, y = score, fill = section)) +
# Half-violin (the "cloud") - shifted right
geom_violin(trim = FALSE, alpha = 0.4,
position = position_nudge(x = 0.15)) +
# Jittered points (the "rain") - shifted left
geom_point(aes(color = section), alpha = 0.4,
position = position_jitter(width = 0.05, seed = 42),
show.legend = FALSE) +
# Boxplot in the middle
geom_boxplot(width = 0.1, alpha = 0.8, outlier.shape = NA) +
labs(title = "Raincloud Plot: Exam Scores by Section",
x = "Section", y = "Score") +
theme_minimal() +
theme(legend.position = "none")
# Raincloud plot for GPA by Sex
# Base R scatterplot
plot(exam_data$study_hours, exam_data$score,
main = "Study Hours vs Score",
xlab = "Study Hours",
ylab = "Score",
pch = 19)
# ggplot2 scatterplot
ggplot(exam_data, aes(x = study_hours, y = score)) +
geom_point() +
labs(title = "Study Hours vs Score", x = "Study Hours", y = "Score") +
theme_minimal()
# Add a linear trend line
ggplot(exam_data, aes(x = study_hours, y = score)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE, color = "blue") +
labs(title = "Study Hours vs Score", x = "Study Hours", y = "Score") +
theme_minimal()
# Color points by section
ggplot(exam_data, aes(x = study_hours, y = score, color = section)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
labs(title = "Study Hours vs Score by Section",
x = "Study Hours", y = "Score") +
theme_minimal()
# Scatterplot of Extraversion vs Neurotocism
# Scatterplot with trend line and color by Sex
# Calculate correlation
cor(exam_data$study_hours, exam_data$score)
# Correlation matrix for numeric columns
cor(exam_data[, c("score", "study_hours")])
# Correlation between personality variables
# Hint: use use = "complete.obs" to handle missing values
# Use R's built-in Anscombe's Quartet
data(anscombe)
# Reshape to long format for easier analysis
anscombe_long <- anscombe |>
pivot_longer(everything(),
names_to = c(".value", "set"),
names_pattern = "(.)(.)")
# All four sets have nearly identical statistics!
anscombe_long |>
group_by(set) |>
summarize(
mean_x = mean(x),
mean_y = mean(y),
sd_x = sd(x),
sd_y = sd(y),
cor = cor(x, y)
)
# But look at the plots...
ggplot(anscombe_long, aes(x = x, y = y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE, color = "blue") +
facet_wrap(~set) +
theme_minimal() +
labs(title = "Anscombe's Quartet: Same Statistics, Very Different Data!")
# Scatterplot matrix with base R
pairs(exam_data[, c("score", "study_hours")])
# More informative scatterplot matrix
ggpairs(exam_data, columns = c("score", "study_hours"),
aes(color = section, alpha = 0.5)) +
theme_minimal()
# Scatterplot matrix for PluckData
ggpairs(pluck_data,
columns = c("GPA", "Extraversion", "Neurotocism"),
aes(alpha=0.5))
# Scatterplot matrix colored by Sex
# Hint: filter out NA Sex values first
ggpairs(pluck_data,
columns = c("GPA", "Extraversion", "Neurotocism"),
aes(color = Sex, alpha=0.5))
View(anscombe)
