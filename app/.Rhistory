ont_index <- base::as.integer(base::readline(prompt = "Enter the number of the ontology to use: "))
if (base::is.na(ont_index) || ont_index < 1 || ont_index > base::length(ontologies)) {
base::stop("Invalid ontology selection.")
}
selected_ont <- ontologies[ont_index]
# --- Step 2: Run GSEA ---
# GSEA strictly requires the list to be sorted descending
desc_gene_list <- base::sort(desc_gene_list, decreasing = TRUE)
gsea_res <- clusterProfiler::gseGO(
geneList      = desc_gene_list,
OrgDb         = org.Hs.eg.db::org.Hs.eg.db,
keyType       = "SYMBOL",
ont           = selected_ont,
minGSSize     = 10,
maxGSSize     = 500,
pvalueCutoff  = 0.05,
verbose       = FALSE,
nPermSimple   = 10000 # Added for stability in newer versions
)
# 🛑 GATEKEEPER: Stop if no results were found
if (base::is.null(gsea_res) || base::nrow(base::as.data.frame(gsea_res)) == 0) {
base::message("⚠️ No significant pathways found for ", selected_ont, ". Exiting.")
return(base::list(msg = "No results found"))
}
# Make gene IDs readable (Uses DOSE/clusterProfiler logic)
gsea_readable <- clusterProfiler::setReadable(
gsea_res,
OrgDb = org.Hs.eg.db::org.Hs.eg.db,
keyType = "SYMBOL"
)
# --- Step 3: Generate cnetplots ---
# Using the most stable argument names for 2025/2026
plots <- base::list()
# Use foldChange directly, NOT inside a list
plots$p1 <- enrichplot::cnetplot(gsea_readable,
foldChange = desc_gene_list,
showCategory = 5)
# categorySize is now often handled via cex_category for scaling
plots$p2 <- enrichplot::cnetplot(gsea_readable,
foldChange = desc_gene_list,
showCategory = 5,
cex_category = 1.5)
plots$p3 <- enrichplot::cnetplot(gsea_readable,
foldChange = desc_gene_list,
circular = TRUE,
colorEdge = TRUE,
showCategory = 5)
# Label Variations
plots$p4 <- enrichplot::cnetplot(gsea_readable, node_label = "category", cex_label_category = 1.2)
plots$p5 <- enrichplot::cnetplot(gsea_readable, node_label = "gene", cex_label_gene = 0.8)
plots$p6 <- enrichplot::cnetplot(gsea_readable, node_label = "all")
plots$p7 <- enrichplot::cnetplot(gsea_readable, node_label = "none")
# --- Step 4: Combine plots ---
# Note: 2026 workflows often prefer plot_list or patchwork, but plot_grid remains solid
plots$grid1 <- cowplot::plot_grid(plots$p1, plots$p2, plots$p3,
ncol = 3, labels = base::LETTERS[1:3],
rel_widths = c(1, 1, 1.2))
plots$grid2 <- cowplot::plot_grid(plots$p4, plots$p5, plots$p6, plots$p7,
ncol = 2, labels = base::LETTERS[4:7])
base::cat("\n✅ GSEA and Cnetplots completed successfully.\n")
return(plots)
}
data[["gene_concept_network"]]$plots_hnpcc_ex_go_bp <- run_gsea_cnet(data$gene_concept_network$all_samples_data$HNPCC_EX)
run_gsea_cnet <- function(desc_gene_list, ontologies = c("BP", "MF", "CC")) {
# --- Step 1: Select ontology ---
base::cat("Available ontologies:\n")
for (i in base::seq_along(ontologies)) base::cat(i, ":", ontologies[i], "\n")
ont_index <- base::as.integer(base::readline(prompt = "Enter the number of the ontology to use: "))
if (base::is.na(ont_index) || ont_index < 1 || ont_index > base::length(ontologies)) {
base::stop("Invalid ontology selection.")
}
selected_ont <- ontologies[ont_index]
# --- Step 2: Run GSEA ---
# GSEA strictly requires sorting descending
desc_gene_list <- base::sort(desc_gene_list, decreasing = TRUE)
gsea_res <- clusterProfiler::gseGO(
geneList      = desc_gene_list,
OrgDb         = org.Hs.eg.db::org.Hs.eg.db,
keyType       = "SYMBOL",
ont           = selected_ont,
minGSSize     = 10,
maxGSSize     = 500,
pvalueCutoff  = 0.05,
verbose       = FALSE
)
# GATEKEEPER: Check if results exist
if (base::is.null(gsea_res) || base::nrow(base::as.data.frame(gsea_res)) == 0) {
base::message("No significant pathways found. Exiting.")
return(base::list())
}
# Convert IDs to readable symbols
gsea_readable <- clusterProfiler::setReadable(gsea_res, OrgDb = org.Hs.eg.db::org.Hs.eg.db)
# --- Step 3: Generate cnetplots ---
plots <- base::list()
# In 2026, cnetplot uses 'color.params' for data and 'size_category' for scaling
params <- base::list(foldChange = desc_gene_list)
# Basic View
plots$p1 <- enrichplot::cnetplot(gsea_readable, showCategory = 5, color.params = params)
# Scaled View (Replaces cex_category with size_category)
plots$p2 <- enrichplot::cnetplot(gsea_readable, showCategory = 5,
color.params = params,
size_category = 1.5)
# Circular View
plots$p3 <- enrichplot::cnetplot(gsea_readable, showCategory = 5,
color.params = params,
circular = TRUE, color_edge = "category")
# Node Labeling (cex_label_category is now size_label_category in some sub-versions)
# but node_label selection remains the same
plots$p4 <- enrichplot::cnetplot(gsea_readable, node_label = "category")
plots$p5 <- enrichplot::cnetplot(gsea_readable, node_label = "gene")
plots$p6 <- enrichplot::cnetplot(gsea_readable, node_label = "all")
plots$p7 <- enrichplot::cnetplot(gsea_readable, node_label = "none")
# --- Step 4: Combine ---
plots$grid1 <- cowplot::plot_grid(plots$p1, plots$p2, plots$p3, ncol = 3, labels = "AUTO")
plots$grid2 <- cowplot::plot_grid(plots$p4, plots$p5, plots$p6, plots$p7, ncol = 2, labels = "AUTO")
base::cat("\n✅ Plotting complete.\n")
return(plots)
}
data[["gene_concept_network"]]$plots_hnpcc_ex_go_bp <- run_gsea_cnet(data$gene_concept_network$all_samples_data$HNPCC_EX)
