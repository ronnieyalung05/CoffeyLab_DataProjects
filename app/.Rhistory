pairs(exam_data[, c("score", "study_hours")])
# Load exam scores data
exam_data <- read.csv("exam_scores.csv")
# Load bimodal data
bimodal <- read.csv("bimodal_mystery.csv")
# Load PluckData
load("PluckData.RData")
